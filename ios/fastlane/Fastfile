default_platform(:ios)

APP_IDENTIFIER = "com.fitnesswispr.app"
APP_NAME = "SpotRep"
# Apple Developer Team ID; provide via env (e.g. export ASC_TEAM_ID=XXXXXXXXXX)
TEAM_ID = ENV["ASC_TEAM_ID"]

def asc_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"],
    in_house: false
  )
end

def spaceship_login
  require "spaceship"
  token = Spaceship::ConnectAPI::Token.create(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    filepath: File.expand_path(ENV["ASC_KEY_PATH"])
  )
  Spaceship::ConnectAPI.token = token
end

platform :ios do
  desc "Verify API credentials by listing apps"
  lane :verify do
    spaceship_login
    apps = Spaceship::ConnectAPI::App.all
    UI.success("Authenticated. Apps visible to this key:")
    apps.each { |a| UI.message("  - #{a.name} (#{a.bundle_id})") }
    UI.message("(no apps yet)") if apps.empty?
  end

  desc "Poll until the agreement block clears"
  lane :poll do
    require "spaceship"
    require "net/http"
    uri = URI("https://api.appstoreconnect.apple.com/v1/apps?limit=1")
    cleared = false
    120.times do
      token = Spaceship::ConnectAPI::Token.create(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        filepath: File.expand_path(ENV["ASC_KEY_PATH"])
      )
      req = Net::HTTP::Get.new(uri)
      req["Authorization"] = "Bearer #{token.text}"
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
      ts = Time.now.strftime("%H:%M:%S")
      if res.code == "200"
        puts "[#{ts}] AGREEMENT_CLEARED http=200"
        cleared = true
        break
      else
        puts "[#{ts}] still_blocked http=#{res.code}"
      end
      sleep 120
    end
    puts "POLL_TIMEOUT" unless cleared
  end

  desc "Create internal beta group and attach the latest build"
  lane :setup_group do
    require "net/http"
    require "json"
    spaceship_login
    token = Spaceship::ConnectAPI.token
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.user_error!("App not found") unless app
    group_name = "Internal Testers"

    api = lambda do |method, path, body = nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      klass = { get: Net::HTTP::Get, post: Net::HTTP::Post }[method]
      req = klass.new(uri)
      req["Authorization"] = "Bearer #{token.text}"
      req["Content-Type"] = "application/json"
      req.body = body.to_json if body
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
      [res.code.to_i, (JSON.parse(res.body) rescue {})]
    end

    # Find or create the internal group
    group = app.get_beta_groups.find { |g| g.name == group_name }
    group_id = group&.id
    if group_id
      UI.success("Beta group already exists: #{group_name}")
    else
      code, resp = api.call(:post, "/v1/betaGroups", {
        data: {
          type: "betaGroups",
          attributes: { name: group_name, isInternalGroup: true },
          relationships: { app: { data: { type: "apps", id: app.id } } }
        }
      })
      UI.user_error!("Group create failed (#{code}): #{resp}") unless code == 201
      group_id = resp.dig("data", "id")
      UI.success("Created internal beta group: #{group_name} (#{group_id})")
    end

    build = Spaceship::ConnectAPI::Build.all(
      app_id: app.id, processing_states: "VALID", limit: 1
    ).first
    UI.user_error!("No processed build found yet") unless build

    code, resp = api.call(:post, "/v1/betaGroups/#{group_id}/relationships/builds", {
      data: [{ type: "builds", id: build.id }]
    })
    if [204, 201, 200].include?(code)
      UI.success("Attached build #{build.app_version} (#{build.version}) to '#{group_name}'")
    else
      UI.important("Build attach returned #{code}: #{resp}")
    end

    UI.message("GROUP_ID=#{group_id}")
  end

  desc "Add App Store Connect users as internal testers"
  lane :add_testers do
    require "net/http"
    require "json"
    spaceship_login
    token = Spaceship::ConnectAPI.token
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    group = app.get_beta_groups.find { |g| g.name == "Internal Testers" }
    UI.user_error!("Internal Testers group not found") unless group

    uri = URI("https://api.appstoreconnect.apple.com/v1/users?limit=200")
    req = Net::HTTP::Get.new(uri)
    req["Authorization"] = "Bearer #{token.text}"
    res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
    users = JSON.parse(res.body)["data"] || []
    UI.message("Account users: #{users.map { |u| u.dig('attributes','username') }.join(', ')}")

    users.each do |u|
      attrs = u["attributes"] || {}
      email = attrs["username"]
      next unless email
      curi = URI("https://api.appstoreconnect.apple.com/v1/betaTesters")
      creq = Net::HTTP::Post.new(curi)
      creq["Authorization"] = "Bearer #{token.text}"
      creq["Content-Type"] = "application/json"
      creq.body = {
        data: {
          type: "betaTesters",
          attributes: { email: email, firstName: attrs["firstName"], lastName: attrs["lastName"] },
          relationships: { betaGroups: { data: [{ type: "betaGroups", id: group.id }] } }
        }
      }.to_json
      cres = Net::HTTP.start(curi.hostname, curi.port, use_ssl: true) { |h| h.request(creq) }
      if %w[200 201].include?(cres.code)
        UI.success("Added internal tester: #{email}")
      else
        detail = (JSON.parse(cres.body)['errors'][0]['detail'] rescue cres.body)
        UI.important("#{email}: HTTP #{cres.code} #{detail}")
      end
    end
  end

  desc "Upload the already-built IPA to TestFlight (internal)"
  lane :upload do
    key = asc_key
    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      ipa: "/tmp/fw_build/Fitnesswispr.ipa",
      skip_submission: true,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Wait until the app record exists"
  lane :wait_app do
    found = false
    60.times do
      spaceship_login
      app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      ts = Time.now.strftime("%H:%M:%S")
      if app
        puts "[#{ts}] APP_RECORD_FOUND #{app.name}"
        found = true
        break
      else
        puts "[#{ts}] app_not_found_yet"
      end
      sleep 20
    end
    puts "WAIT_APP_TIMEOUT" unless found
  end

  desc "Show TestFlight status"
  lane :status do
    spaceship_login
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.message("App: #{app.name} (#{APP_IDENTIFIER}) id=#{app.id}")
    app.get_beta_groups.each do |g|
      kind = g.is_internal_group ? "internal" : "external"
      UI.message("Group: #{g.name} [#{kind}]")
    end
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, limit: 1).first
    UI.message("Latest build #{build&.app_version} (#{build&.version}): processing_state=#{build&.processing_state}") if build
  end

  desc "Raw API diagnostic"
  lane :diag do
    require "spaceship"
    require "json"
    require "net/http"
    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      filepath: File.expand_path(ENV["ASC_KEY_PATH"])
    )
    uri = URI("https://api.appstoreconnect.apple.com/v1/apps?limit=5")
    req = Net::HTTP::Get.new(uri)
    req["Authorization"] = "Bearer #{token.text}"
    res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
    UI.message("HTTP #{res.code}")
    UI.message(res.body)
  end

  desc "Create the app record on App Store Connect"
  lane :create_app do
    spaceship_login

    bundle = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
    if bundle
      UI.success("Bundle ID already registered: #{APP_IDENTIFIER}")
    else
      Spaceship::ConnectAPI::BundleId.create(
        name: "Fitnesswispr",
        platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS,
        identifier: APP_IDENTIFIER,
        seed_id: TEAM_ID
      )
      UI.success("Registered bundle ID: #{APP_IDENTIFIER}")
    end

    existing = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    if existing
      UI.success("App already exists: #{existing.name} (#{APP_IDENTIFIER})")
    else
      Spaceship::ConnectAPI::App.create(
        name: APP_NAME,
        version_string: "1.0",
        sku: "fitnesswispr-001",
        primary_locale: "en-US",
        bundle_id: APP_IDENTIFIER,
        platforms: [Spaceship::ConnectAPI::Platform::IOS]
      )
      UI.success("Created app record: #{APP_NAME}")
    end
  end

  desc "Archive + export the IPA only (no upload)"
  lane :archive do
    asc_key
    build_app(
      project: "Fitnesswispr.xcodeproj",
      scheme: "Fitnesswispr",
      configuration: "Release",
      output_directory: "/tmp/fw_build",
      output_name: "Fitnesswispr.ipa",
      derived_data_path: "/tmp/fw_dd_release",
      clean: true,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )
  end

  # ---- Public (external) TestFlight beta -------------------------------------
  #
  # Required env (personal / Apple-required info):
  #   BETA_FEEDBACK_EMAIL   where tester feedback is sent
  #   BETA_CONTACT_FIRST    review contact first name
  #   BETA_CONTACT_LAST     review contact last name
  #   BETA_CONTACT_EMAIL    review contact email
  #   BETA_CONTACT_PHONE    review contact phone (e.g. +1 555 123 4567)
  #   BETA_PRIVACY_URL      public privacy policy URL
  # Optional:
  #   BETA_PUBLIC_LIMIT     max public-link testers (default 1000)
  #   BETA_MARKETING_URL    marketing/website URL
  #   BETA_GROUP_NAME       external group name (default "Public Beta")
  BETA_DESCRIPTION = <<~DESC.strip
    SpotRep is the fastest way to log your lifts. Record a set by voice
    ("bench 3x10 at 135"), by typing, or by importing a spreadsheet or photo of
    an old log. See your training consistency at a glance, tap a muscle to see
    what to train next, and share progress with a spotter who can view — or log
    on your behalf. No account required; optional Sign in with Apple backs up and
    syncs your data.
  DESC

  BETA_WHATS_TO_TEST = <<~TEST.strip
    Thanks for testing SpotRep! Please try:
    - Logging a workout by voice, by typing, and by importing a spreadsheet/photo
    - Editing/deleting a workout and changing a workout's date
    - The consistency heatmap and tapping a day / a muscle group
    - Adding a spotter (share invite), then revoking / stopping spotting
    - Exporting your workouts to CSV/Excel
    Send feedback via TestFlight's screenshot tool, or email us.
  TEST

  desc "Set up the external (public) TestFlight group and submit for Beta App Review"
  lane :public_beta do
    require "net/http"
    require "json"

    missing = %w[BETA_FEEDBACK_EMAIL BETA_CONTACT_FIRST BETA_CONTACT_LAST
                 BETA_CONTACT_EMAIL BETA_CONTACT_PHONE BETA_PRIVACY_URL]
              .reject { |k| ENV[k].to_s.strip != "" }
    UI.user_error!("Missing required env: #{missing.join(', ')}") unless missing.empty?

    group_name = ENV["BETA_GROUP_NAME"] || "Public Beta"
    public_limit = (ENV["BETA_PUBLIC_LIMIT"] || "1000").to_i

    spaceship_login
    token = Spaceship::ConnectAPI.token
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.user_error!("App not found") unless app

    api = lambda do |method, path, body = nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      klass = { get: Net::HTTP::Get, post: Net::HTTP::Post,
                patch: Net::HTTP::Patch, delete: Net::HTTP::Delete }[method]
      req = klass.new(uri)
      req["Authorization"] = "Bearer #{token.text}"
      req["Content-Type"] = "application/json"
      req.body = body.to_json if body
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
      [res.code.to_i, (JSON.parse(res.body) rescue {})]
    end

    # Latest processed build.
    build = Spaceship::ConnectAPI::Build.all(
      app_id: app.id, processing_states: "VALID", limit: 1
    ).first
    UI.user_error!("No processed (VALID) build found yet") unless build
    UI.message("Using build #{build.app_version} (#{build.version})")

    # 1) External group with a public link.
    code, resp = api.call(:get, "/v1/apps/#{app.id}/betaGroups?limit=200")
    group = (resp["data"] || []).find { |g| g.dig("attributes", "name") == group_name }
    group_attrs = {
      name: group_name,
      publicLinkEnabled: true,
      publicLinkLimitEnabled: true,
      publicLinkLimit: public_limit,
      feedbackEnabled: true
    }
    if group
      gid = group["id"]
      api.call(:patch, "/v1/betaGroups/#{gid}", {
        data: { type: "betaGroups", id: gid, attributes: group_attrs }
      })
      UI.success("Updated external group '#{group_name}' (#{gid})")
    else
      code, resp = api.call(:post, "/v1/betaGroups", {
        data: {
          type: "betaGroups",
          attributes: group_attrs.merge(isInternalGroup: false),
          relationships: { app: { data: { type: "apps", id: app.id } } }
        }
      })
      UI.user_error!("Group create failed (#{code}): #{resp}") unless code == 201
      gid = resp.dig("data", "id")
      UI.success("Created external group '#{group_name}' (#{gid})")
    end

    # 2) Beta App Review contact info.
    code, resp = api.call(:get, "/v1/apps/#{app.id}/betaAppReviewDetail")
    detail_id = resp.dig("data", "id")
    review_attrs = {
      contactFirstName: ENV["BETA_CONTACT_FIRST"],
      contactLastName: ENV["BETA_CONTACT_LAST"],
      contactEmail: ENV["BETA_CONTACT_EMAIL"],
      contactPhone: ENV["BETA_CONTACT_PHONE"],
      demoAccountRequired: false
    }
    if detail_id
      api.call(:patch, "/v1/betaAppReviewDetails/#{detail_id}", {
        data: { type: "betaAppReviewDetails", id: detail_id, attributes: review_attrs }
      })
      UI.success("Set Beta App Review contact info")
    else
      UI.important("No betaAppReviewDetail found to update")
    end

    # 3) Test Information (feedback email, description, privacy URL) for en-US.
    code, resp = api.call(:get, "/v1/apps/#{app.id}/betaAppLocalizations?limit=200")
    loc = (resp["data"] || []).find { |l| l.dig("attributes", "locale") == "en-US" }
    loc_attrs = {
      feedbackEmail: ENV["BETA_FEEDBACK_EMAIL"],
      description: BETA_DESCRIPTION,
      privacyPolicyUrl: ENV["BETA_PRIVACY_URL"],
      marketingUrl: ENV["BETA_MARKETING_URL"]
    }.reject { |_, v| v.nil? }
    if loc
      lid = loc["id"]
      api.call(:patch, "/v1/betaAppLocalizations/#{lid}", {
        data: { type: "betaAppLocalizations", id: lid, attributes: loc_attrs }
      })
      UI.success("Updated Test Information (en-US)")
    else
      api.call(:post, "/v1/betaAppLocalizations", {
        data: {
          type: "betaAppLocalizations",
          attributes: loc_attrs.merge(locale: "en-US"),
          relationships: { app: { data: { type: "apps", id: app.id } } }
        }
      })
      UI.success("Created Test Information (en-US)")
    end

    # 4) "What to Test" notes for this build (en-US).
    code, resp = api.call(:get, "/v1/builds/#{build.id}/betaBuildLocalizations?limit=200")
    bloc = (resp["data"] || []).find { |l| l.dig("attributes", "locale") == "en-US" }
    if bloc
      bid = bloc["id"]
      api.call(:patch, "/v1/betaBuildLocalizations/#{bid}", {
        data: { type: "betaBuildLocalizations", id: bid, attributes: { whatsNew: BETA_WHATS_TO_TEST } }
      })
    else
      api.call(:post, "/v1/betaBuildLocalizations", {
        data: {
          type: "betaBuildLocalizations",
          attributes: { locale: "en-US", whatsNew: BETA_WHATS_TO_TEST },
          relationships: { build: { data: { type: "builds", id: build.id } } }
        }
      })
    end
    UI.success("Set 'What to Test' notes")

    # 5) Attach the build to the external group.
    code, resp = api.call(:post, "/v1/betaGroups/#{gid}/relationships/builds", {
      data: [{ type: "builds", id: build.id }]
    })
    UI.success("Attached build to '#{group_name}' (#{code})")

    # 6) Submit the build for Beta App Review.
    code, resp = api.call(:post, "/v1/betaAppReviewSubmissions", {
      data: {
        type: "betaAppReviewSubmissions",
        relationships: { build: { data: { type: "builds", id: build.id } } }
      }
    })
    if code == 201
      UI.success("Submitted build #{build.version} for Beta App Review 🎉")
    elsif code == 409
      UI.important("Build already submitted / in review (409)")
    else
      UI.important("Beta review submission returned #{code}: #{resp}")
    end

    # 7) Print the public link (may be nil until review approves).
    code, resp = api.call(:get, "/v1/betaGroups/#{gid}")
    link = resp.dig("data", "attributes", "publicLink")
    UI.message("PUBLIC_LINK=#{link || '(available after Beta App Review approval)'}")
  end

  desc "Invite an external tester by email to an external group (default 'Public Beta')"
  lane :invite_tester do
    require "net/http"
    require "json"
    email = ENV["TESTER_EMAIL"].to_s.strip
    UI.user_error!("Set TESTER_EMAIL") if email.empty?
    group_name = ENV["BETA_GROUP_NAME"] || "Public Beta"

    spaceship_login
    token = Spaceship::ConnectAPI.token
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)

    api = lambda do |method, path, body = nil|
      uri = URI("https://api.appstoreconnect.apple.com#{path}")
      klass = { get: Net::HTTP::Get, post: Net::HTTP::Post }[method]
      req = klass.new(uri)
      req["Authorization"] = "Bearer #{token.text}"
      req["Content-Type"] = "application/json"
      req.body = body.to_json if body
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
      [res.code.to_i, (JSON.parse(res.body) rescue {})]
    end

    code, resp = api.call(:get, "/v1/apps/#{app.id}/betaGroups?limit=200")
    group = (resp["data"] || []).find { |g| g.dig("attributes", "name") == group_name }
    UI.user_error!("External group '#{group_name}' not found — run `fastlane public_beta` first") unless group
    gid = group["id"]

    attrs = { email: email }
    attrs[:firstName] = ENV["TESTER_FIRST"] if ENV["TESTER_FIRST"].to_s.strip != ""
    attrs[:lastName] = ENV["TESTER_LAST"] if ENV["TESTER_LAST"].to_s.strip != ""

    code, resp = api.call(:post, "/v1/betaTesters", {
      data: {
        type: "betaTesters",
        attributes: attrs,
        relationships: { betaGroups: { data: [{ type: "betaGroups", id: gid }] } }
      }
    })
    if [200, 201].include?(code)
      UI.success("Invited #{email} to '#{group_name}'")
    elsif code == 409
      # Tester already exists — just add them to this group.
      code2, list = api.call(:get, "/v1/betaTesters?filter[email]=#{URI.encode_www_form_component(email)}")
      tid = (list["data"] || []).first&.dig("id")
      if tid
        ac, _ = api.call(:post, "/v1/betaGroups/#{gid}/relationships/betaTesters", {
          data: [{ type: "betaTesters", id: tid }]
        })
        UI.success("Added existing tester #{email} to '#{group_name}' (#{ac})")
      else
        UI.important("Tester exists but couldn't be located to add to group")
      end
    else
      detail = (resp.dig("errors", 0, "detail") rescue resp)
      UI.important("Invite returned #{code}: #{detail}")
    end
  end

  desc "Print the public TestFlight link and review status"
  lane :public_beta_status do
    require "net/http"
    require "json"
    spaceship_login
    token = Spaceship::ConnectAPI.token
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    group_name = ENV["BETA_GROUP_NAME"] || "Public Beta"
    uri = URI("https://api.appstoreconnect.apple.com/v1/apps/#{app.id}/betaGroups?limit=200")
    req = Net::HTTP::Get.new(uri)
    req["Authorization"] = "Bearer #{token.text}"
    res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
    data = (JSON.parse(res.body)["data"] rescue [])
    g = data.find { |x| x.dig("attributes", "name") == group_name }
    if g
      a = g["attributes"]
      UI.message("Group '#{group_name}': publicLinkEnabled=#{a['publicLinkEnabled']} limit=#{a['publicLinkLimit']}")
      UI.message("PUBLIC_LINK=#{a['publicLink'] || '(pending Beta App Review approval)'}")
    else
      UI.important("External group '#{group_name}' not found — run `fastlane public_beta` first")
    end
    build = Spaceship::ConnectAPI::Build.all(app_id: app.id, limit: 1).first
    UI.message("Latest build #{build&.app_version} (#{build&.version}): #{build&.processing_state}")
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    key = asc_key
    # gym auto-injects -allowProvisioningUpdates + the App Store Connect API key
    # auth flags into the export when a key is in context, so xcodebuild can
    # create/refresh the Distribution cert + app-store profile on the fly.
    # signingStyle: automatic lets it resolve the profile without a manual map.
    # Manual export signing with a profile created via the API key. The key's
    # role can't do xcodebuild "cloud signing", so we pre-create the cert
    # (fastlane cert) + app-store profile (fastlane sigh) and map it here.
    profile_name = ENV["ASC_PROFILE_NAME"] || "com.fitnesswispr.app AppStore"
    build_app(
      project: "Fitnesswispr.xcodeproj",
      scheme: "Fitnesswispr",
      configuration: "Release",
      output_directory: "/tmp/fw_build",
      output_name: "Fitnesswispr.ipa",
      derived_data_path: "/tmp/fw_dd_release",
      clean: true,
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: ENV["ASC_TEAM_ID"],
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )
    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false
    )
  end
end
